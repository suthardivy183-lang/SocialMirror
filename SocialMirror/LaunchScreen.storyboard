                            <constraint firstItem="LaunchImg" firstAttribute="trailing" secondItem="LaunchView" secondAttribute="trailing" id="c2"/>
                            <constraint firstItem="LaunchImg" firstAttribute="top" secondItem="LaunchView" secondAttribute="top" id="c3"/>
                            <constraint firstItem="LaunchImg" firstAttribute="bottom" secondItem="LaunchView" secondAttribute="bottom" id="c4"/>
                        </constraints>
